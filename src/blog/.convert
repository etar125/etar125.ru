#!/bin/env tclsh
# etar125's blog generator for ssgc
# v0.26.7_13

set dir [lindex $argv 0]
set md_handler [list n1md]

set version "0.26.7_13"

set blogname "Мой блог"
set blogolink "/blog"
set bloglink "https://etar125.ru/blog"
set blogdescription "Просто мой блог"

set spisok "# $blogname

\[RSS Feed\](/$dir/rss.xml)  

"


set rss_feed "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<rss version=\"2.0\" xmlns:content=\"http://purl.org/rss/1.0/modules/content/\">
<channel>
<title>$blogname</title>
<link>$bloglink</link>
<description>$blogdescription</description>
<language>ru-ru</language>
"

foreach f [lsort -decreasing -dict [glob -nocomplain -directory $dir -type f *.md]] {
    set root [file rootname $f]
    set up [read [open $f r]]
    set new [open ${root}_new.md w]
    
    set err no

    # id_date_name or id_name
    # 1_first
    # 125_2026-03-13_bye
    set rootps [split $root "_"]
    set newroot [lindex $rootps end]

    set name ${newroot}
    set date "-"
    set pdate "-"

    set hasname no
    set hasdate no

    puts $new "?opt class blog
?open div"
    
    foreach line [split $up "\n"] {
        if {!$hasname && [lindex $line 0] == "#"} {
            puts $new "?opt class post-title
$line

"
            set name [string range $line 2 end]
            set hasname yes
        } elseif {!$hasdate && [lindex $line 0] == "###"} {
            set date [string range $line 4 end]
            set pdate $date
            if {[catch {set date [exec date -d "$date" "+%d.%m.%Y %H:%M"]}]} {
                puts "error while processing ${f}: incorrect date"
                set err yes
                break
            }
            puts $new "?opt class post-date
### $date

"
            set hasdate yes
        } else { puts $new $line }
    }

    puts $new "
?close div"

    close $new

    if {!$err && $date == "-"} {
        puts "error while processing ${f}: no date"
        set err yes
    }
    
    if {!$err && [catch {exec {*}$md_handler ${root}_new.md >> $dir/${newroot}.html} error_msg]} {
        puts "error while converting ${root}_new.md: ${error_msg}"
        set err yes
    }
    
    file delete $f
    file delete ${root}_new.md

    if {$err} { continue }
    
    set fhp [open $dir/${newroot}.html r]
    set fh [read $fhp]
    close $fhp
    set sv [split $fh "\n"]
    set fh [join [lrange $sv 1 end-2] "\n"]
    set fh2 [join [lrange $sv 7 end-2] "\n"]
    
    append rss_feed "<item>
  <title><!\[CDATA\[$name\]\]></title>
  <link>$bloglink/${newroot}.html</link>
  <guid>$bloglink/${newroot}.html</guid>
  <pubDate>[exec date -d "$pdate" -R]</pubDate>
  <description><!\[CDATA\[$fh2\]\]></description>
</item>
"
    append spisok "\[$name\]($blogolink/${newroot}.html)  
"
}

append rss_feed "</channel>
</rss>"

set _sp [open $dir/index.md w]
puts $_sp $spisok
close $_sp
if {[catch {exec {*}$md_handler $dir/index.md > $dir/index.html} error_msg]} {
    puts "error while converting $dir/index.md: ${error_msg}"
}
file delete $dir/index.md

set _rss [open $dir/rss.xml w]
puts $_rss $rss_feed
close $_rss
