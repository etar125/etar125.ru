body {
    background-color: #010101;
    color: #efefef;
    font-family: sans-serif;
    padding: 0;
    margin: 0;
}

pre {
    margin: 0;
}

a {
    color: #2296f0;
}
a:visited {
    color: #59b3f8;
}

#nav a {
    text-decoration: none;
}

#nav a:hover {
    background-color: #ddd;
}

h1 {
    margin: 1em 1ex 0.5ex 0;
    font-size: 1.4em;
}

h2 {
    margin: 1em 1ex 0.5ex 0;
    font-size: 1.3em;
}

h3 {
    margin: 1em 1ex 0.5ex 0;
    font-size: 1.0em;
}

h4 {
    margin: 1em 1ex 0.5ex 0;
    font-size: 0.9em;
}


#nav {
    float: left;
    margin: 0 1px 0 0;
    padding: 1em 0;
    border-right: 1px dotted #ccc;
    width: 200px;
}

#nav ul {
    margin: 0;
    padding: 0;
}

#nav li {
    list-style: none;
    padding: 0;
    margin: 0;
}

#nav li ul {
    padding-left: 0.6em !important;
}

#nav li a {
    display: block;
    margin: 0;
    padding: 0.8ex 2em 0.8ex 1em;
}

#main {
    margin: 0 0 0 200px;
    max-width: 50em;
    padding: 1.5em;
}

#main ul, ol {
    margin-top: 10px;
    margin-bottom: 10px;
    /*padding-left: 30px;*/
}


