#!/bin/env tclsh
# etar125's blog generator for e1sg

set blogname "Мои статьи"
set bloglink "https://etar125.ru/articles"
set blogdescription "Просто мои статьи"

if {$verbose} {
    puts "etar125's blog generator for e1sg"
}

set spisok "?opt noheaderlink yes
# $blogname

\[RSS Feed\](/$dir/rss.xml)  
\[В виде ленты\](/$dir/)  
\[Список тегов\](/$dir/tags.html)

"

set lenta "<h1>$blogname</h1>
<p>
<a href=\"/$dir/rss.xml\">RSS Feed</a><br>
<a href=\"/$dir/spisok.html\">В виде списка</a><br>
<a href=\"/$dir/tags.html\">Список тегов</a>
</p>
"

array set gtags {}

set rss_feed "<?xml version=\"1.0\" encoding=\"UTF-8\"?>
<rss version=\"2.0\" xmlns:content=\"http://purl.org/rss/1.0/modules/content/\">
<channel>
<title>$blogname</title>
<link>$bloglink</link>
<description>$blogdescription</description>
<language>ru-ru</language>
"

foreach f [lsort -decreasing -dict [glob -nocomplain -directory $dir -type f *.md]] {
    if {[lsearch -exact $ignore_convert $f] != -1} { continue }
    if {$verbose} { puts "  processing & converting file $f" }
    set root [file rootname $f]
    set up [read [open $f r]]
    set new [open ${root}_new.md w]
    # name {Делаем деньгу}
    # date {2020-10-10}
    # или
    # date {3030-20-20 13:37}
    # tags {tag1 {tag 2}}
    set pat yes
    set chk yes
    foreach line [split $up "\n"] {
        if {$chk && $line == "?com e1bloggen"} {
            puts $new "?opt class blog
?open div
?opt noheaderlink a
?opt class post_title
# $name
?opt noheaderlink a
?opt class post_date
### [exec date -d "$date" "+%d.%m.%Y %H:%M"]"
            set ota no
            foreach tag $tags {
                if {!$ota} {
                    set ota yes
                    puts -nonewline $new "?opt class post_tags
?open span
Теги: "
                }
                puts $new "\[$tag\](/$dir/$tag.html)"
            }
            if {$ota} { puts $new "?close span" }
            puts $new "?com e1bloggen header end\n\n"
            append spisok "\[$name\](/$dir/${root}.html) $date  \n"
            foreach tag $tags {
                append gtags($tag) "\[$name\](/$dir/${root}.html) $date  \n"
            }
            set pat no
            set chk no
            continue
        }
        if {$pat} {
            eval "set $line"
        } else {
            puts $new $line
        }
    }
    
    puts -nonewline $new "\n?close div\n"
    close $new
    
    if {[catch {exec {*}$md_handler ${root}_new.md >> ${root}.html} error_msg]} {
        puts "error while converting ${root}_new.md: ${error_msg}"
        continue
    }
    
    file delete $f
    file delete ${root}_new.md
    
    set fhp [open ${root}.html r]
    set fh [read $fhp]
    close $fhp
    set sv {}
    
    set sh no
    
    foreach line [split $fh "\n"] {
        if {!$sh} {
            if {$line == "<!--e1bloggen header end-->"} {
                set sh yes
            }
        } else {
            append sv "$line\n"
        }
    }
    
    append rss_feed "<item>
  <title><!\[CDATA\[$name\]\]></title>
  <link>$bloglink/${root}.html</link>
  <guid>$bloglink/${root}.html</guid>
  <pubDate>[exec date -d "$date" -R]</pubDate>
  <description><!\[CDATA\[$sv\]\]></description>
</item>
"
    append lenta "<hr>
$fh
"
}

append rss_feed "</channel>
</rss>"

if {$verbose} {
    puts "tags:"
}

set tgs [open $dir/tags.html w]

foreach tag [array names gtags] {
    if {$verbose} {
        puts "  $tag"
    }
    set fp [open $dir/$tag.md w]
    puts $fp "# Тег $tag\n"
    puts $fp $gtags($tag)
    close $fp
    if {[catch {exec {*}$md_handler $dir/$tag.md >> $dir/$tag.html} error_msg]} {
        puts "error while converting $dir/$tag.md: ${error_msg}"
        continue
    }
    file delete $dir/$tag.md
    puts $tgs "<a href=\"/$dir/$tag.html\">$tag</a>"
}

close $tgs

set _sp [open $dir/spisok.md w]
puts $_sp $spisok
close $_sp
if {[catch {exec {*}$md_handler $dir/spisok.md >> $dir/spisok.html} error_msg]} {
    puts "error while converting $dir/spisok.md: ${error_msg}"
}
file delete $dir/spisok.md

set _lp [open $dir/index.html w]
puts $_lp $lenta
close $_lp

set _rss [open $dir/rss.xml w]
puts $_rss $rss_feed
close $_rss
